# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── LM Studio ────────────────────────────────────────────────────────────────
# The base URL of your LM Studio server (no trailing slash, no /v1).
# Example: http://localhost:1234  or  http://10.0.0.x:1234
LM_STUDIO_URL=your-lm-studio-ip-here:1234

# The exact model identifier as it appears in LM Studio's model list.
# Example: qwen3.5
LM_STUDIO_MODEL=your-model-name-here

# ── Anthropic (optional — for future Claude integration) ─────────────────────
ANTHROPIC_API_KEY=

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Bot token from discord.com/developers — required to run the bot.
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs Selene will respond to and learn from.
# Example: 466372090531151882,123456789012345678
DISCORD_ALLOWED_USERS=466372090531151882

# Comma-separated channel IDs Selene monitors (leave blank = all DMs only).
DISCORD_HOME_CHANNEL=

# ── Obsidian ──────────────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault root. Used by ManifestTool to sync
# development_manifest.md, philosophy_manifest.md, and prioritization_guidelines.md.
# Example: C:\Users\rcole\Documents\Obsidian Vault
OBSIDIAN_VAULT_PATH=

# ── Notion ────────────────────────────────────────────────────────────────────
# Integration token from notion.so/my-integrations (starts with "secret_").
NOTION_API_KEY=

# ── Google Workspace ─────────────────────────────────────────────────────────
# Path to the OAuth2 client secrets JSON downloaded from Google Cloud Console.
# Run scripts/google_setup.py once to authorise and generate google_token.json.
# Example: C:\Users\rcole\Github Projects\google_client_secret.json
GOOGLE_CLIENT_SECRET_PATH=

# ── Spotify ───────────────────────────────────────────────────────────────────
# From developer.spotify.com/dashboard — create an app to get these.
# Redirect URI must be set to http://localhost:8888/callback in the Spotify app.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ── Home Assistant ────────────────────────────────────────────────────────────
# Local HA instance URL and a Long-Lived Access Token (Profile → Security).
# Leave blank to keep HomeAssistantTool dormant.
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=
