# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── LM Studio ────────────────────────────────────────────────────────────────
# The base URL of your LM Studio server (no trailing slash, no /v1).
# Example: http://localhost:1234  or  http://192.168.1.x:1234
LM_STUDIO_URL=http://localhost:1234

# The exact model identifier as it appears in LM Studio's model list.
# Example: nvidia/nemotron-3-nano-4b
LM_STUDIO_MODEL=your-model-name-here

# ── Anthropic (optional — for future Claude integration) ─────────────────────
ANTHROPIC_API_KEY=
